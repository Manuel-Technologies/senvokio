{
  "name": "senviok",
  "version": "1.0.0",
  "description": "Developer-friendly email infrastructure for African startups — powered by AWS SES",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "worker": "tsx src/workers/emailWorker.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.600.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@prisma/client": "^5.16.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "mjml": "^4.15.3",
    "nanoid": "^3.3.7",
    "pino": "^9.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/mjml": "^4.7.4",
    "@types/node": "^20.14.10",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.16.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
