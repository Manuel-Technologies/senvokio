# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/senviok?schema=public"

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# ─── AWS SES ───────────────────────────────────────────────────────────────────
# Prefer IAM roles in production (EC2/ECS). Use keys only for local dev.
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=af-south-1

# ─── SES Config ────────────────────────────────────────────────────────────────
# SNS topic ARN for SES event notifications (bounces, complaints, opens)
SES_SNS_TOPIC_ARN=arn:aws:sns:af-south-1:123456789:senviok-ses-events

# ─── Webhooks ──────────────────────────────────────────────────────────────────
# Secret for verifying incoming SES/SNS webhook payloads
WEBHOOK_SECRET=your-webhook-secret

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
